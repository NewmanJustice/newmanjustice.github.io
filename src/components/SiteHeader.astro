---
import { url } from '@/lib/url';

const pathname = Astro.url.pathname;

const nav = [
  { label: 'Writing', href: url('posts/') },
  { label: 'About', href: url('about/') },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href={url('')} class="wordmark" aria-label="NewmanJustice — home">
      <span class="wordmark-name">NewmanJustice</span>
    </a>

    <nav aria-label="Site navigation">
      <ul>
        {nav.map(({ label, href }) => (
          <li>
            <a
              href={href}
              aria-current={pathname.startsWith(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: color-mix(in srgb, var(--color-canvas) 92%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .wordmark {
    text-decoration: none;
  }

  .wordmark-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }

  .wordmark-name:hover {
    color: var(--color-accent);
  }

  nav ul {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  nav a {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  nav a:hover,
  nav a[aria-current="page"] {
    color: var(--color-ink);
  }

  nav a[aria-current="page"] {
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--color-olive);
  }
</style>
