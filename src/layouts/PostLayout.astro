---
import BaseLayout from './BaseLayout.astro';
import { type CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  seriesSlug?: string;
  seriesTitle?: string;
  siblings?: CollectionEntry<'posts'>[];
}

const { post, seriesSlug, seriesTitle, siblings = [] } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Find prev/next within series
const currentIndex = siblings.findIndex(s => s.id === post.id);
const prev = currentIndex > 0 ? siblings[currentIndex - 1] : null;
const next = currentIndex < siblings.length - 1 ? siblings[currentIndex + 1] : null;
---

<BaseLayout title={`${title} — NewmanJustice`} description={description}>
  <article class="post-article">
    <div class="post-container">

      {seriesSlug && (
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/posts/">Writing</a>
          <span aria-hidden="true">/</span>
          <a href={`/posts/${seriesSlug}/`}>{seriesTitle}</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{title}</span>
        </nav>
      )}

      <header class="post-header">
        <div class="post-meta">
          <time datetime={pubDate.toISOString()}>
            {dateFormatter.format(pubDate)}
          </time>
          {updatedDate && (
            <span class="updated">
              Updated <time datetime={updatedDate.toISOString()}>{dateFormatter.format(updatedDate)}</time>
            </span>
          )}
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        {tags.length > 0 && (
          <ul class="tag-list" aria-label="Tags">
            {tags.map(tag => <li class="tag">{tag}</li>)}
          </ul>
        )}
      </header>

      <div class="post-body prose">
        <slot />
      </div>

      {siblings.length > 0 && (
        <nav class="series-nav" aria-label="Series navigation">
          {prev && (
            <a href={`/posts/${seriesSlug}/${prev.slug.split('/')[1]}/`} class="series-nav-link prev">
              <span class="nav-label">Previous</span>
              <span class="nav-title">{prev.data.title}</span>
            </a>
          )}
          {next && (
            <a href={`/posts/${seriesSlug}/${next.slug.split('/')[1]}/`} class="series-nav-link next">
              <span class="nav-label">Next</span>
              <span class="nav-title">{next.data.title}</span>
            </a>
          )}
        </nav>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .post-article {
    padding: 3rem 1.5rem 6rem;
  }

  .post-container {
    max-width: 42rem;
    margin: 0 auto;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin-bottom: 2.5rem;
  }

  .breadcrumb a {
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin-bottom: 1rem;
    display: flex;
    gap: 1.5rem;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }

  .post-description {
    font-size: 1.125rem;
    color: var(--color-ink-muted);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background-color: var(--color-surface);
    color: var(--color-ink-muted);
    padding: 0.2em 0.6em;
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
  }

  .post-body {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-ink);
  }

  .post-body :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 2.5rem 0 1rem;
    color: var(--color-ink);
  }

  .post-body :global(h3) {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }

  .post-body :global(p) {
    margin: 0 0 1.5rem;
  }

  .post-body :global(pre) {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 1.5rem 0;
  }

  .post-body :global(code:not(pre code)) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding-left: 1.25rem;
    color: var(--color-ink-muted);
    font-style: italic;
    margin: 1.5rem 0;
  }

  .post-body :global(ul), .post-body :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.5rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-underline-offset: 3px;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .series-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .series-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    max-width: 48%;
  }

  .series-nav-link.next {
    margin-left: auto;
    text-align: right;
  }

  .nav-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink-muted);
    font-family: var(--font-mono);
  }

  .nav-title {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-ink);
    transition: color 0.15s;
  }

  .series-nav-link:hover .nav-title {
    color: var(--color-accent);
  }
</style>
