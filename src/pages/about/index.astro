---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — NewmanJustice"
  description="Principal Developer at HM Courts and Tribunals Service. Writing about technology in context."
>
  <div class="about-page">
    <div class="about-inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">NewmanJustice</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">About</span>
      </nav>

      <h1 class="about-title">About</h1>

      <div class="about-body">
        <p>
          I'm a Principal Developer at <a href="https://www.gov.uk/government/organisations/hm-courts-and-tribunals-service" target="_blank" rel="noopener noreferrer">HM Courts and Tribunals Service</a>, part of the Ministry of Justice. My work sits at the intersection of complex public-sector delivery and modern software engineering practice.
        </p>
        <p>
          This site is where I think out loud. The writing here covers technology in context — not technology for its own sake, but for what it does in practice: how it shapes teams, changes processes, introduces risk, and occasionally, when conditions are right, genuinely improves things.
        </p>
        <p>
          I'm particularly interested in what happens when powerful capabilities (AI, large-scale integrations, automated decision support) meet environments where the consequences of getting things wrong are serious and the constraints are real.
        </p>
        <p>
          On GitHub I'm <a href="https://github.com/NewmanJustice" target="_blank" rel="noopener noreferrer">NewmanJustice</a>.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    padding: 4rem 1.5rem 8rem;
    min-height: 80vh;
  }
  .about-inner {
    max-width: 42rem;
    margin: 0 auto;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin-bottom: 3rem;
  }
  .breadcrumb a {
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .breadcrumb a:hover { color: var(--color-accent); }

  .about-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0 0 2.5rem;
    line-height: 1;
  }

  .about-body {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-ink);
  }
  .about-body p {
    margin: 0 0 1.5rem;
  }
  .about-body a {
    color: var(--color-accent);
    text-underline-offset: 3px;
  }
</style>
