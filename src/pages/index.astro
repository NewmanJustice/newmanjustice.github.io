---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CharacterSVG from '@/components/CharacterSVG.astro';
import { url } from '@/lib/url';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', p => !p.data.draft);

// Series = parent posts (no series field)
const seriesPosts = allPosts
  .filter(p => !p.data.series)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Child count per series
const childCounts: Record<string, number> = {};
for (const post of allPosts.filter(p => p.data.series)) {
  const s = post.data.series!;
  childCounts[s] = (childCounts[s] ?? 0) + 1;
}

const poses = ['thinking', 'reading', 'writing', 'presenting'] as const;
type Pose = typeof poses[number];
---

<BaseLayout
  title="NewmanJustice — the thoughts and ramblings of a principal developer"
  description="Technology in context. The thoughts and ramblings of a principal developer at HM Courts and Tribunals Service."
>
  <div class="home">

    <section class="hero">
      <div class="hero-inner">
        <p class="tagline">the thoughts and ramblings of&hellip;</p>
        <h1 class="site-title">Newman<br/>Justice</h1>
        <p class="strapline">
          Principal Developer &middot; HMCTS &middot; Technology in context, and its impact on the craft of software engineering.
        </p>
      </div>
    </section>

    <section class="writing-section" aria-labelledby="writing-heading">
      <div class="section-inner">
        <h2 class="section-label" id="writing-heading">Writing</h2>

        {seriesPosts.length === 0 ? (
          <p class="empty-state">Nothing published yet. Watch this space.</p>
        ) : (
          <ul class="character-grid" role="list">
            {seriesPosts.map((post, i) => {
              const seriesSlug = post.slug;
              const pose: Pose = poses[i % poses.length];
              const count = childCounts[seriesSlug] ?? 0;
              return (
                <li>
                  <a href={url(`posts/${seriesSlug}/`)} class="character-card">
                    <div class="card-top">
                      <div class="thought-bubble">
                        <span class="bubble-title">{post.data.title}</span>
                        <span class="bubble-meta">
                          {count > 0 ? `${count} entr${count === 1 ? 'y' : 'ies'}` : 'Series intro'}
                        </span>
                      </div>
                    </div>
                    <div class="thought-chain" aria-hidden="true">
                      <span class="tc-dot tc-lg"></span>
                      <span class="tc-dot tc-md"></span>
                      <span class="tc-dot tc-sm"></span>
                    </div>
                    <div class="character-figure" aria-hidden="true">
                      <CharacterSVG pose={pose} index={i} />
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        )}
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .home { min-height: 80vh; }

  /* Hero */
  .hero {
    padding: 5rem 1.5rem 4rem;
    border-bottom: 1px solid var(--color-border);
  }
  .hero-inner {
    max-width: 72rem;
    margin: 0 auto;
  }
  .tagline {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 1.25rem;
  }
  .site-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 10vw, 8rem);
    font-weight: 600;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0 0 2rem;
  }
  .strapline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-ink-muted);
    max-width: 42rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Writing section */
  .writing-section {
    padding: 4rem 1.5rem 6rem;
  }
  .section-inner {
    max-width: 72rem;
    margin: 0 auto;
  }
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 3rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-olive);
  }
  .empty-state {
    color: var(--color-ink-muted);
    font-style: italic;
  }

  /* Character grid */
  .character-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: 2.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .character-card {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    text-decoration: none;
    transition: transform 0.2s ease;
  }
  .character-card:hover {
    transform: translateY(-4px);
  }
  .character-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 0.25rem;
  }

  .character-figure {
    width: 100%;
    padding: 0 1rem;
    margin-top: -0.75rem;
  }

  /* Bubble sits right; left gap keeps it visually above the character's head */
  .card-top {
    display: flex;
    justify-content: flex-end;
    padding-right: 0.5rem;
  }

  /* Thought bubble — clean rounded rect, no pseudo-elements */
  .thought-bubble {
    width: 78%;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  .character-card:hover .thought-bubble {
    background-color: var(--color-accent-dark);
    border-color: var(--color-accent-dark);
  }

  /* Dot chain — large near bubble, small near head.
     Centred at ~52% to sit above the character's head */
  .thought-chain {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-left: 49%;
    gap: 0.35rem;
    padding-top: 0.25rem;
    padding-bottom: 0;
  }
  .tc-dot {
    border-radius: 50%;
    background-color: var(--color-border);
    flex-shrink: 0;
    transition: background-color 0.2s ease;
  }
  .tc-lg { width: 11px; height: 11px; }
  .tc-md { width:  8px; height:  8px; }
  .tc-sm { width:  5px; height:  5px; }

  .character-card:hover .tc-dot {
    background-color: var(--color-terracotta);
  }

  .bubble-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.3;
    transition: color 0.2s ease;
  }
  .bubble-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-ink-muted);
    letter-spacing: 0.04em;
    transition: color 0.2s ease;
  }
  .character-card:hover .bubble-title,
  .character-card:hover .bubble-meta {
    color: var(--color-canvas);
  }
</style>
