---
import DesktopLayout from '@/layouts/DesktopLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', p => !p.data.draft);

const seriesParents = allPosts
  .filter(p => !p.data.series)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const childrenBySeries: Record<string, typeof allPosts> = {};
for (const post of allPosts.filter(p => p.data.series)) {
  const s = post.data.series!;
  (childrenBySeries[s] ??= []).push(post);
}
for (const slug of Object.keys(childrenBySeries)) {
  childrenBySeries[slug].sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
}

const rendered = await Promise.all(
  allPosts.map(async (post) => {
    const { Content } = await post.render();
    return { slug: post.slug.replace(/\//g, '-'), Content };
  })
);
---

<DesktopLayout
  title="NewmanJustice — GEM Desktop"
  description="Technology in context. The thoughts and ramblings of a principal developer at HM Courts and Tribunals Service."
>
  <div id="desktop">

    <div id="menu-bar">
      <span class="gem-menu-item">DESK</span>
      <span class="gem-menu-item">DATEI</span>
      <span class="gem-menu-item">INDEX</span>
      <span class="gem-menu-item">EXTRAS</span>
    </div>

    <div id="desktop-area">
      <div
        id="hdd-icon"
        data-hdd
        class="gem-icon gem-hdd"
        tabindex="0"
        role="button"
        aria-label="Hard Disk"
        data-series-json={JSON.stringify(
          seriesParents.map(p => ({
            slug: p.slug,
            title: p.data.title,
            children: (childrenBySeries[p.slug] ?? []).map(c => ({
              slug: c.slug.replace(/\//g, '-'),
              title: c.data.title,
            })),
          }))
        )}
      >
        <div class="gem-icon-img" aria-hidden="true">
          <svg width="48" height="40" viewBox="0 0 48 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1" y="1" width="46" height="38" fill="var(--color-window-bg)" stroke="var(--color-border)" stroke-width="2"/>
            <rect x="5" y="5" width="38" height="22" fill="var(--color-border)"/>
            <circle cx="36" cy="32" r="3" fill="var(--color-border)"/>
          </svg>
        </div>
        <span class="gem-icon-label">HARD DISK</span>
      </div>
    </div>

    <div id="modal-layer"></div>

  </div>

  <div id="post-store" hidden>
    {rendered.map(({ slug, Content }) => (
      <div id={`post-html-${slug}`} hidden>
        <Content />
      </div>
    ))}
  </div>

</DesktopLayout>

<script is:inline>
(function () {
  let zCounter = 10;

  function bringToFront(el) {
    el.style.zIndex = ++zCounter;
  }

  function closeWindow(el) {
    el.remove();
  }

  let windowCount = 0;
  function cascadeOffset() {
    return windowCount * 24;
  }

  function makeDraggable(win, handle) {
    let startX, startY, startLeft, startTop;
    handle.addEventListener('mousedown', function (e) {
      e.preventDefault();
      startX = e.clientX;
      startY = e.clientY;
      startLeft = win.offsetLeft;
      startTop = win.offsetTop;
      function onMove(e) {
        win.style.left = (startLeft + e.clientX - startX) + 'px';
        win.style.top = (startTop + e.clientY - startY) + 'px';
      }
      function onUp() {
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
      }
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });
  }

  function createWindow(title, contentEl) {
    const offset = cascadeOffset();
    windowCount++;
    const win = document.createElement('div');
    win.className = 'gem-window';
    win.setAttribute('role', 'dialog');
    win.setAttribute('aria-label', title);
    win.style.cssText = 'position:absolute;left:' + (60 + offset) + 'px;top:' + (40 + offset) + 'px;min-width:280px;min-height:160px;background:var(--color-window-bg);border:2px solid var(--color-border);display:flex;flex-direction:column;pointer-events:auto;resize:both;overflow:hidden;';
    bringToFront(win);

    const titleBar = document.createElement('div');
    titleBar.className = 'gem-titlebar';
    titleBar.style.cssText = 'display:flex;align-items:center;background:var(--color-titlebar);color:var(--color-titlebar-text);padding:0 4px;height:20px;gap:4px;cursor:move;flex-shrink:0;';

    const closeBtn = document.createElement('button');
    closeBtn.className = 'gem-close';
    closeBtn.setAttribute('aria-label', 'Close');
    closeBtn.style.cssText = 'width:12px;height:12px;background:var(--color-window-bg);border:1px solid var(--color-border);padding:0;cursor:pointer;flex-shrink:0;';
    closeBtn.addEventListener('click', function () { closeWindow(win); });

    const titleText = document.createElement('span');
    titleText.style.cssText = 'flex:1;font-size:11px;font-family:monospace;text-align:center;user-select:none;';
    titleText.textContent = title;

    titleBar.appendChild(closeBtn);
    titleBar.appendChild(titleText);
    win.appendChild(titleBar);
    win.appendChild(contentEl);

    win.addEventListener('mousedown', function () { bringToFront(win); });
    win.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') { closeWindow(win); }
    });

    makeDraggable(win, titleBar);

    document.getElementById('modal-layer').appendChild(win);
    win.focus();
    return win;
  }

  function openDriveWindow() {
    const hdd = document.querySelector('[data-hdd]');
    const seriesData = JSON.parse(hdd.getAttribute('data-series-json') || '[]');

    const body = document.createElement('div');
    body.style.cssText = 'flex:1;padding:12px;display:flex;flex-wrap:wrap;gap:16px;align-content:flex-start;overflow:auto;';

    for (const series of seriesData) {
      const icon = document.createElement('div');
      icon.className = 'gem-folder-icon';
      icon.setAttribute('data-series', series.slug);
      icon.setAttribute('tabindex', '0');
      icon.setAttribute('role', 'button');
      icon.setAttribute('aria-label', series.title);
      icon.style.cssText = 'display:flex;flex-direction:column;align-items:center;gap:4px;cursor:default;padding:4px;width:64px;';
      icon.innerHTML = '<svg width="40" height="32" viewBox="0 0 40 32" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="1" y="8" width="38" height="23" fill="var(--color-window-bg)" stroke="var(--color-border)" stroke-width="2"/><rect x="1" y="4" width="18" height="6" fill="var(--color-window-bg)" stroke="var(--color-border)" stroke-width="2"/></svg><span style="font-size:10px;font-family:monospace;text-align:center;word-break:break-word;max-width:60px;">' + series.title + '</span>';
      icon.addEventListener('dblclick', function () { openFolderWindow(series.slug); });
      icon.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { openFolderWindow(series.slug); }
      });
      body.appendChild(icon);
    }

    createWindow('HARD DISK', body);
  }

  function openFolderWindow(seriesSlug) {
    const hdd = document.querySelector('[data-hdd]');
    const seriesData = JSON.parse(hdd.getAttribute('data-series-json') || '[]');
    const series = seriesData.find(function (s) { return s.slug === seriesSlug; });
    if (!series) return;

    const entries = series.children.length > 0 ? series.children : [{ slug: seriesSlug, title: series.title }];
    const body = document.createElement('div');
    body.style.cssText = 'flex:1;padding:12px;display:flex;flex-wrap:wrap;gap:16px;align-content:flex-start;overflow:auto;';

    for (const entry of entries) {
      const icon = document.createElement('div');
      icon.className = 'gem-file-icon';
      icon.setAttribute('data-slug', entry.slug);
      icon.setAttribute('tabindex', '0');
      icon.setAttribute('role', 'button');
      icon.setAttribute('aria-label', entry.title);
      icon.style.cssText = 'display:flex;flex-direction:column;align-items:center;gap:4px;cursor:default;padding:4px;width:64px;';
      const safeName = (entry.slug.split('-').pop() || entry.slug).toUpperCase() + '.TXT';
      icon.innerHTML = '<svg width="32" height="40" viewBox="0 0 32 40" fill="none" xmlns="http://www.w3.org/2000/svg"><polygon points="22,1 31,10 31,39 1,39 1,1" fill="var(--color-window-bg)" stroke="var(--color-border)" stroke-width="2"/><polyline points="22,1 22,10 31,10" fill="none" stroke="var(--color-border)" stroke-width="2"/></svg><span style="font-size:10px;font-family:monospace;text-align:center;word-break:break-word;max-width:60px;">' + safeName + '</span>';
      icon.addEventListener('dblclick', function () { openFileWindow(entry.slug); });
      icon.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { openFileWindow(entry.slug); }
      });
      body.appendChild(icon);
    }

    createWindow(series.title.toUpperCase(), body);
  }

  function openFileWindow(slug) {
    var storeEl = document.getElementById('post-html-' + slug);
    var body = document.createElement('div');
    body.className = 'gem-post-content';
    body.style.cssText = 'flex:1;padding:24px 28px;overflow-y:auto;font-family:monospace;font-size:13px;line-height:1.7;background:var(--color-window-bg);';
    if (storeEl) {
      body.innerHTML = storeEl.innerHTML;
    } else {
      body.textContent = '(Post content not found)';
    }
    var title = slug.toUpperCase() + '.TXT';
    var win = createWindow(title, body);
    win.style.width = '620px';
    win.style.height = '480px';
  }

  // Event wiring — script is inline at end of body, DOM is ready
  var hdd = document.querySelector('[data-hdd]');
  if (hdd) {
    hdd.addEventListener('dblclick', openDriveWindow);
    hdd.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { openDriveWindow(); }
    });
  }

  var modalLayer = document.getElementById('modal-layer');
  if (modalLayer) {
    modalLayer.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        var win = e.target.closest('.gem-window');
        if (win) { closeWindow(win); }
      }
    });
  }
})();
</script>

<style>
  #desktop {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    background-color: var(--color-desktop);
    background-image: radial-gradient(var(--color-desktop-dot) 1px, transparent 1px);
    background-size: 8px 8px;
    font-family: var(--font-mono, monospace);
    overflow: hidden;
  }

  #menu-bar {
    display: flex;
    flex-shrink: 0;
    background-color: var(--color-menubar);
    border-bottom: 2px solid var(--color-border);
    height: 24px;
    align-items: center;
    gap: 0;
    z-index: 100;
  }

  .gem-menu-item {
    padding: 0 12px;
    font-size: 12px;
    color: var(--color-ink);
    cursor: default;
    height: 100%;
    display: flex;
    align-items: center;
    border-right: 1px solid var(--color-border);
    user-select: none;
  }
  .gem-menu-item:first-child {
    border-left: 1px solid var(--color-border);
  }

  #desktop-area {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  .gem-icon {
    position: absolute;
    top: 24px;
    right: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    cursor: default;
    padding: 4px;
    user-select: none;
  }
  .gem-icon:focus {
    outline: none;
  }
  .gem-icon:focus .gem-icon-label,
  .gem-icon.selected .gem-icon-label {
    background-color: var(--color-selected-bg);
    color: var(--color-selected-text);
  }

  .gem-icon-label {
    font-size: 11px;
    color: var(--color-titlebar-text);
    background-color: transparent;
    padding: 1px 3px;
    text-align: center;
    white-space: nowrap;
  }

  #modal-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  #modal-layer > * {
    pointer-events: auto;
  }
</style>

<style is:global>
  .gem-post-content h1 {
    font-size: 1.4em;
    font-weight: 700;
    margin: 0 0 0.8em;
    padding-bottom: 0.4em;
    border-bottom: 2px solid var(--color-border);
  }
  .gem-post-content h2 {
    font-size: 1.2em;
    font-weight: 700;
    margin: 1.4em 0 0.6em;
    padding-bottom: 0.3em;
    border-bottom: 1px solid var(--color-border);
  }
  .gem-post-content h3 {
    font-size: 1.05em;
    font-weight: 700;
    margin: 1.2em 0 0.4em;
  }
  .gem-post-content p {
    margin: 0 0 0.8em;
  }
  .gem-post-content ul,
  .gem-post-content ol {
    margin: 0 0 0.8em;
    padding-left: 1.6em;
  }
  .gem-post-content li {
    margin-bottom: 0.3em;
  }
  .gem-post-content li::marker {
    color: var(--color-ink);
  }
  .gem-post-content blockquote {
    margin: 0.8em 0;
    padding: 0.4em 0.8em;
    border-left: 3px solid var(--color-border);
    background: rgba(0,0,0,0.04);
  }
  .gem-post-content code {
    font-family: monospace;
    font-size: 0.9em;
    background: rgba(0,0,0,0.06);
    padding: 0.1em 0.3em;
    border: 1px solid rgba(0,0,0,0.1);
  }
  .gem-post-content pre {
    margin: 0.8em 0;
    padding: 0.8em;
    background: rgba(0,0,0,0.06);
    border: 1px solid rgba(0,0,0,0.1);
    overflow-x: auto;
  }
  .gem-post-content pre code {
    background: none;
    border: none;
    padding: 0;
  }
  .gem-post-content a {
    color: var(--color-ink);
    text-decoration: underline;
  }
  .gem-post-content strong {
    font-weight: 700;
  }
  .gem-post-content em {
    font-style: italic;
  }
  .gem-post-content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 1.2em 0;
  }

  /* Visible scrollbar for GEM windows */
  .gem-post-content::-webkit-scrollbar {
    width: 16px;
  }
  .gem-post-content::-webkit-scrollbar-track {
    background: var(--color-window-bg);
    border-left: 1px solid var(--color-border);
  }
  .gem-post-content::-webkit-scrollbar-thumb {
    background: var(--color-menubar);
    border: 1px solid var(--color-border);
  }
</style>
