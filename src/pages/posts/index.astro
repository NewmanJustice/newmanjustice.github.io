---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', p => !p.data.draft);

const seriesPosts = allPosts
  .filter(p => !p.data.series)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const childCounts: Record<string, number> = {};
for (const post of allPosts.filter(p => p.data.series)) {
  const s = post.data.series!;
  childCounts[s] = (childCounts[s] ?? 0) + 1;
}

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
});
---

<BaseLayout
  title="Writing — NewmanJustice"
  description="All writing, journals and papers by NewmanJustice."
>
  <div class="posts-page">
    <header class="page-header">
      <div class="page-header-inner">
        <p class="page-super">NewmanJustice</p>
        <h1 class="page-title">Writing</h1>
        <p class="page-desc">
          Journals, papers and learning records. Technology in context — and its impact on the craft of software engineering.
        </p>
      </div>
    </header>

    <div class="posts-list-wrap">
      <ul class="posts-list" role="list">
        {seriesPosts.map(post => (
          <li>
            <a href={`/posts/${post.slug}/`} class="series-row">
              <div class="series-row-body">
                <h2 class="series-title">{post.data.title}</h2>
                <p class="series-desc">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <ul class="tag-list" aria-label="Tags">
                    {post.data.tags.map(tag => <li class="tag">{tag}</li>)}
                  </ul>
                )}
              </div>
              <div class="series-row-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {dateFormatter.format(post.data.pubDate)}
                </time>
                <span class="series-count">
                  {(childCounts[post.slug] ?? 0)} entr{(childCounts[post.slug] ?? 0) === 1 ? 'y' : 'ies'}
                </span>
                <span class="series-arrow" aria-hidden="true">&rarr;</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</BaseLayout>

<style>
  .posts-page { min-height: 80vh; }

  .page-header {
    padding: 4rem 1.5rem 3rem;
    border-bottom: 1px solid var(--color-border);
  }
  .page-header-inner {
    max-width: 72rem;
    margin: 0 auto;
  }
  .page-super {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 0.75rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0 0 1rem;
    line-height: 1;
  }
  .page-desc {
    font-size: 1.0625rem;
    color: var(--color-ink-muted);
    max-width: 38rem;
    line-height: 1.6;
    margin: 0;
  }

  .posts-list-wrap {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .series-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: background-color 0.15s;
  }
  .series-row:hover .series-title {
    color: var(--color-accent);
  }
  .series-row:hover .series-arrow {
    transform: translateX(4px);
  }
  .series-row:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 0.25rem;
  }

  .series-row-body { flex: 1; min-width: 0; }

  .series-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    line-height: 1.25;
    transition: color 0.15s;
  }
  .series-desc {
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    background-color: var(--color-surface);
    color: var(--color-ink-muted);
    padding: 0.2em 0.55em;
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
  }

  .series-row-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
    flex-shrink: 0;
    padding-top: 0.25rem;
  }
  .series-row-meta time {
    font-size: 0.8125rem;
    color: var(--color-ink-muted);
    font-family: var(--font-mono);
  }
  .series-count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-ink-muted);
  }
  .series-arrow {
    font-size: 1.125rem;
    color: var(--color-border);
    transition: transform 0.2s ease, color 0.15s;
    margin-top: 0.5rem;
  }
  .series-row:hover .series-arrow {
    color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .series-row { flex-direction: column; gap: 1rem; }
    .series-row-meta { align-items: flex-start; flex-direction: row; flex-wrap: wrap; }
  }
</style>
